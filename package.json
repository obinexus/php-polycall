{
  "name": "@obinexusltd/php-polycall",
  "version": "1.0.0",
  "description": "PHP FFI source binding for libpolycall 1.5",
  "main": "index.js",
  "type": "commonjs",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./composer.json": "./composer.json",
    "./src/*": "./src/*",
    "./generated/*": "./generated/*",
    "./dist/*": "./dist/*",
    "./examples/*": "./examples/*",
    "./tests/*": "./tests/*",
    "./scripts/*": "./scripts/*",
    "./config": "./php-polycallrc",
    "./manifest": "./polycall-binding.json"
  },
  "files": [
    "index.js",
    "composer.json",
    "src/",
    "generated/",
    "dist/",
    "examples/",
    "tests/",
    "scripts/",
    "php-polycallrc",
    "polycall-binding.json",
    "README.md",
    "TODO.md",
    "LICENSE"
  ],
  "directories": {
    "lib": "src",
    "src": "src",
    "generated": "generated",
    "dist": "dist",
    "example": "examples",
    "test": "tests",
    "scripts": "scripts"
  },
  "scripts": {
    "test": "node tests/package.test.js && node tests/source.test.js && node scripts/test-php-if-available.js",
    "test:package": "node tests/package.test.js",
    "test:source": "node tests/source.test.js",
    "test:php": "node scripts/test-php-if-available.js --required",
    "verify": "npm test",
    "prepack": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obinexus/php-polycall.git"
  },
  "keywords": [
    "libpolycall",
    "polycall",
    "php",
    "ffi",
    "native"
  ],
  "author": "Nnamdi Michael Okpala <okpalan@protonmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/obinexus/php-polycall/issues"
  },
  "homepage": "https://github.com/obinexus/php-polycall#readme"
}
